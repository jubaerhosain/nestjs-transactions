{
  "name": "@nestjs-transactions/core",
  "version": "0.4.2",
  "description": "ORM-agnostic building blocks for declarative transaction propagation in NestJS, built on @nestjs-cls/transactional",
  "license": "MIT",
  "author": "Jubaer Hosain",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jubaerhosain/nestjs-transactions.git",
    "directory": "packages/core"
  },
  "homepage": "https://jubaerhosain.github.io/nestjs-transactions/",
  "keywords": [
    "nestjs",
    "transactional",
    "transaction",
    "cls",
    "async-local-storage",
    "typeorm-transactional"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "testing": [
        "dist/testing/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "test:unit": "jest"
  },
  "peerDependencies": {
    "@nestjs-cls/transactional": "^3.2.0",
    "@nestjs/common": ">= 10 < 12",
    "@nestjs/core": ">= 10 < 12",
    "nestjs-cls": "^6.2.0",
    "reflect-metadata": "*",
    "rxjs": ">= 7"
  },
  "devDependencies": {
    "@nestjs-cls/transactional": "^3.2.1",
    "@nestjs/common": "^11.1.28",
    "@nestjs/core": "^11.1.28",
    "@nestjs/testing": "^11.1.28",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.13.3",
    "jest": "^29.7.0",
    "nestjs-cls": "^6.2.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  }
}
