{
  "name": "@nestjs-transactions/prisma",
  "version": "1.0.1",
  "description": "Declarative @Transactional() for NestJS + Prisma: inject one transaction-aware Prisma client, drop the $transaction boilerplate. No monkey-patching.",
  "license": "MIT",
  "author": "Jubaer Hosain",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jubaerhosain/nestjs-transactions.git",
    "directory": "packages/prisma"
  },
  "keywords": [
    "nestjs",
    "prisma",
    "transactional",
    "transaction",
    "cls",
    "async-local-storage"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "testing": [
        "dist/testing/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "prisma generate && tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "test:unit": "jest",
    "test:int": "prisma db push --accept-data-loss && jest --config jest.integration.config.js --runInBand"
  },
  "peerDependencies": {
    "@nestjs-cls/transactional": "^3.2.0",
    "@nestjs-cls/transactional-adapter-prisma": "^1.3.0",
    "@nestjs-transactions/core": "^0.4.2",
    "@nestjs/common": ">= 10 < 12",
    "@nestjs/core": ">= 10 < 12",
    "@prisma/client": "> 4 < 8",
    "nestjs-cls": "^6.2.0"
  },
  "devDependencies": {
    "@nestjs-cls/transactional": "^3.2.1",
    "@nestjs-cls/transactional-adapter-prisma": "^1.3.5",
    "@nestjs-transactions/core": "workspace:^",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/testing": "^11.1.27",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.13.2",
    "jest": "^29.7.0",
    "nestjs-cls": "^6.2.1",
    "prisma": "^7.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.4.11",
    "typescript": "^5.9.3"
  }
}
