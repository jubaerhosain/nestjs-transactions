{
  "name": "@nestjs-transactions/typeorm",
  "version": "4.0.4",
  "description": "Declarative @Transactional() for NestJS + TypeORM: keep @InjectRepository, drop the boilerplate. Drop-in replacement DX for typeorm-transactional without monkey-patching.",
  "license": "MIT",
  "author": "Jubaer Hosain",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jubaerhosain/nestjs-transactions.git",
    "directory": "packages/typeorm"
  },
  "keywords": [
    "nestjs",
    "typeorm",
    "transactional",
    "typeorm-transactional",
    "transaction",
    "cls",
    "async-local-storage",
    "repository"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "typesVersions": {
    "*": {
      "testing": [
        "dist/testing/index.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "jest",
    "test:unit": "jest",
    "test:int": "jest --config jest.integration.config.js --runInBand"
  },
  "peerDependencies": {
    "@nestjs-cls/transactional": "^3.2.0",
    "@nestjs-cls/transactional-adapter-typeorm": "^1.3.0",
    "@nestjs-transactions/core": "^0.4.2",
    "@nestjs/common": ">= 10 < 12",
    "@nestjs/core": ">= 10 < 12",
    "@nestjs/typeorm": ">= 10 < 12",
    "nestjs-cls": "^6.2.0",
    "typeorm": "^0.3.2 || ^1.0.0"
  },
  "devDependencies": {
    "@nestjs-cls/transactional": "^3.2.1",
    "@nestjs-cls/transactional-adapter-typeorm": "^1.3.5",
    "@nestjs-transactions/core": "workspace:^",
    "@nestjs/common": "^11.1.27",
    "@nestjs/core": "^11.1.27",
    "@nestjs/testing": "^11.1.27",
    "@nestjs/typeorm": "^11.0.3",
    "@types/jest": "^29.5.14",
    "@types/node": "^24.13.2",
    "jest": "^29.7.0",
    "nestjs-cls": "^6.2.1",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.4.11",
    "typeorm": "^0.3.30",
    "typescript": "^5.9.3"
  }
}
